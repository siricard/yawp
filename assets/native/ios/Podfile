# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'MookNative' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Workaround for Xcode 26 / Apple Clang 17+ which rejects fmt 11.0.2's
    # consteval-based compile-time format string checking. Compile only the
    # `fmt` pod in C++17 so FMT_USE_CONSTEVAL collapses to the runtime
    # constexpr path. All other pods stay on C++20 (required by RN internals).
    # See facebook/react-native#55601. Remove after RN bumps fmt to >= 12.1.
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end
    end

    # Workaround for Xcode 26's `ld` rejecting `-objc_abi_version` when passed
    # directly. The link command Xcode generates for the app target's debug
    # dylib mixes clang-only flags (`-fobjc-link-runtime`) with the raw
    # `-Xlinker -objc_abi_version -Xlinker 2` pair. Invoking `ld` directly
    # fails with `ld: -objc_abi_version '-Xlinker' not supported (expected 2)`.
    # Forcing the linker driver back to `clang`/`clang++` (which knows how to
    # translate those flags) restores the prior behavior. Apply to the
    # `MookNative` app target only — Pods targets compile fine with default
    # settings. Remove once RN bumps past 0.81 (>= 0.84 uses prebuilt binaries).
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.targets.each do |target|
        next unless target.name == 'MookNative'
        target.build_configurations.each do |config|
          config.build_settings['LD'] = 'clang'
          config.build_settings['LDPLUSPLUS'] = 'clang++'
        end
      end
      aggregate_target.user_project.save
    end
  end
end
