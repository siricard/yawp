# Yawp self-hosting environment template.
#
# Copy this file to `.env` (next to docker-compose.yml) and fill in real
# values BEFORE running `docker compose up -d`. Never commit your `.env`.
#
#   cp .env.example .env
#   # ...edit values below...
#   docker compose up -d
#
# Generate the app secrets with:
#   openssl rand -base64 64 | tr -d '\n'
#   openssl rand -base64 48 | tr -d '\n'

# --- Phoenix ------------------------------------------------------------------

# Public hostname the server is reachable at (no scheme, no port).
# Used to build URLs (verified routes, channel origins, etc.).
PHX_HOST=localhost

# Host-side port the Phoenix container is published on. Defaults to 4000.
# Set to 80 (or front it with a reverse proxy + TLS) for a public deployment.
PHX_PORT=4000

# 64+ byte random string. Signs/encrypts cookies and Plug session payloads.
# Regenerating invalidates all existing sessions -- do this once per deployment.
SECRET_KEY_BASE=CHANGE_ME

# 64+ byte random string. Signs AshAuthentication tokens. Independent of
# SECRET_KEY_BASE; regenerating invalidates all issued auth tokens.
TOKEN_SIGNING_SECRET=CHANGE_ME

# CLOAK_KEY — required in production. Encrypts the federation server
# private key at rest via ash_cloak. Generate with: mix yawp.gen.cloak_key
# (or: openssl rand -base64 32). Must be base64 of 32 raw bytes.
CLOAK_KEY=

# 48+ byte random string. Signs attachment download URLs. Independent of
# SECRET_KEY_BASE so cookie/session rotation does not silently change URL
# signing semantics.
# Generate with: openssl rand -base64 48 | tr -d '\n'
ATTACHMENT_SIGNING_SECRET=CHANGE_ME

# Absolute path inside the Phoenix container where local attachment files live.
# Mount a persistent volume at this path when running in containers.
UPLOADS_DIR=/data/uploads

# --- Postgres -----------------------------------------------------------------

# Credentials for the bundled `postgres` service. Defaults work out of the box
# but you SHOULD change POSTGRES_PASSWORD before exposing anything publicly.
POSTGRES_USER=yawp
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=yawp_prod

# Connection string Phoenix uses to reach Postgres. The hostname `postgres`
# refers to the sibling compose service.
#
# Build it from the values above:
#   scheme:   ecto
#   user:     value of POSTGRES_USER
#   password: value of POSTGRES_PASSWORD (URL-encode if it contains @ / : etc.)
#   host:     postgres
#   db:       value of POSTGRES_DB
#
# If you point Yawp at an external Postgres instead, fill in your own URL
# and remove the postgres service from docker-compose.yml.
DATABASE_URL=

# --- Container image (optional) -----------------------------------------------

# Override the published image tag when pulling from GHCR. Leave commented to
# default to `ghcr.io/siricard/yawp:latest`, or set to a specific version
# like `ghcr.io/siricard/yawp:v0.1.0` for pinned deploys.
# YAWP_IMAGE=ghcr.io/siricard/yawp:latest
